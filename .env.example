# ARTickle Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file with real values to git.

# -------------------------------------------------------
# Firebase Web SDK (client-side — safe to expose in browser, protected by Firestore rules)
# -------------------------------------------------------
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# -------------------------------------------------------
# Master admin (comma-separated emails that get auto-admin on first login)
# -------------------------------------------------------
VITE_MASTER_ADMIN_EMAILS=admin@yourdomain.com

# -------------------------------------------------------
# App config
# -------------------------------------------------------
VITE_APP_NAME=ARTickle Academy
VITE_DEFAULT_CURRENCY=SAR
VITE_CURRENCY_SYMBOL=ر.س

# -------------------------------------------------------
# Future: Zoom / online lesson integration
# -------------------------------------------------------
# VITE_ZOOM_SDK_KEY=
# VITE_ZOOM_SDK_SECRET=   <-- DO NOT put SDK secret here (use backend only)

# -------------------------------------------------------
# NOTE: firebase-service-account.json must NEVER be committed.
# It is for server-side / admin SDK use only (CI/CD, Cloud Functions).
# Store it as a secret in your CI/CD system (GitHub Actions secrets, etc.)
# -------------------------------------------------------
